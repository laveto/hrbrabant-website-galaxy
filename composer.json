{
    "name": "laveto/lav-galaxy-boilerplate",
    "type": "project",
    "description": "An app around the (inner) Galaxy Framework. Use this project to clone your next Galaxy project.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "laveto/lav-galaxy-framework": "~2.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "galaxy",
            "options": {
                "symlink": true
            }
        },
        {
            "type": "vcs",
            "url": "https://github.com/TheoGibbons/scout"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3"
        },
        "allow-plugins": {
            "sllh/composer-versions-check": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "exclude-from-classmap": [
            "/**/resources"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "pre-install-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "(php -r \"die(file_exists('/home/forge') ? 1 : 0);\" && php artisan ide-helper:generate) || echo \"Skip ide-helper generate\"",
            "(php -r \"die(file_exists('/home/forge') ? 1 : 0);\" && php artisan ide-helper:meta) || echo \"Skip ide-helper meta\"",
            "(php -r \"die(file_exists('/home/forge') ? 1 : 0);\" && php artisan ide-helper:models -W -R) || echo \"Skip ide-helper models\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
