[
    {
        "name": "artisan-queue-worker",
        "script": "artisan",
        "args": [
            "queue:work",
            "--tries=5",
            "--sleep=1",
            "--timeout=30",
            "--queue=default,media,website-cache-html"
        ],
        "exec_interpreter": "php",
        "exec_mode": "fork_mode",
        "interpreter_args": "-d memory_limit=1G",
        "max_memory_restart": "1G",
        "ignore_watch": [
            "galaxy/node_scripts",
            "galaxy/node_modules",
            "galaxy/boilerplate",
            "galaxy/docs",
            "node_modules",
            "node_scripts",
            "bootstrap",
            "database",
            "storage",
            "public",
            "routes",
            "vendor",
            "tests"
        ],
        "watch": true,
        "merge_logs": true
    }
]
